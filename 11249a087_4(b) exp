#include <stdio.h>
#include <unistd.h>
#include <stdlib.h>
#include <sys/wait.h>
int main(void)
{
    int pid, status, exitch;

    if ((pid = fork()) == -1)
    {
        perror("Fork error");
        exit(1);
    }

    if (pid == 0)
    {
        // Child process
        sleep(1);
        printf("Child process\n");
        exit(0);
    }
    else
    {
        // Parent process
        printf("Parent process\n");

        if ((exitch = wait(&status)) == -1)
        {
            perror("Error during wait()");
            exit(1);
        }

        printf("Child with PID %d finished\n", exitch);
        printf("Parent exiting\n");
        exit(0);
    }
}
