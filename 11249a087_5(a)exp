#include <stdio.h>
#include <unistd.h>
#include <sys/types.h>
int main(void)
{
    pid_t value;
    value = fork();
    if (value < 0)
    {
        perror("Fork failed");
        return 1;
    }
    else if (value == 0)
    {
        // Child process
        printf("Child process: value = %d\n", value);
    }
    else
    {
        // Parent process
        printf("Parent process: value = %d\n", value);
    }

    return 0;
}
