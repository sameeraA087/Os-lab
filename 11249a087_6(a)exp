#include <stdio.h>

struct process
{
    int burst, wait;
} p[20];

int main(void)
{
    int n, i;
    int totalwait = 0, totalturn = 0;

    printf("Enter the number of processes: ");
    scanf("%d", &n);

    // Input burst times
    for (i = 0; i < n; i++)
    {
        printf("Enter burst time (in ms) for Process #%d: ", i + 1);
        scanf("%d", &p[i].burst);
    }

    // First process waiting time is 0
    p[0].wait = 0;

    // Calculate waiting times
    for (i = 1; i < n; i++)
    {
        p[i].wait = p[i - 1].wait + p[i - 1].burst;
    }

    printf("\nProcess\tWaiting Time\tTurnaround Time\n");

    // Display results
    for (i = 0; i < n; i++)
    {
        int turnaround = p[i].wait + p[i].burst;

        printf("P%d\t%d\t\t%d\n", i + 1, p[i].wait, turnaround);

        totalwait += p[i].wait;
        totalturn += turnaround;
    }

    printf("\nAverage Waiting Time: %.2f ms", totalwait / (float)n);
    printf("\nAverage Turnaround Time: %.2f ms\n", totalturn / (float)n);

    return 0;
}
