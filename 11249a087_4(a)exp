#include <stdio.h>
#include <unistd.h>
#include <sys/types.h>
#include <sys/stat.h>
#include <stdlib.h>
int main(void)
{
    char path[100];
    struct stat nfile;
    printf("Enter name of file whose statistics have to be displayed: ");
    scanf("%s", path);
    // Check if stat call is successful
    if (stat(path, &nfile) == -1) {
        perror("stat");
        return 1;
    }
    printf("User ID: %d\n", nfile.st_uid);
    printf("Block size: %ld\n", nfile.st_blksize);
    printf("Last access time: %ld\n", nfile.st_atime);
    printf("Last modification time: %ld\n", nfile.st_mtime);
    printf("File mode: %o\n", nfile.st_mode);
    printf("File size: %ld bytes\n", nfile.st_size);
    printf("Number of links: %ld\n", nfile.st_nlink);
    return 0;
}
